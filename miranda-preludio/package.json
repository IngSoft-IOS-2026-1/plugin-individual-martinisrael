{
  "name": "miranda-preludio",
  "displayName": "Miranda Prelude",
  "description": "%extension.description%",
  "version": "1.0.1",
  "publisher": "martinisrael",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/IngSoft-IOS-2026-1/plugin-individual-martinisrael",
    "directory": "miranda-preludio"
  },
  "bugs": {
    "url": "https://github.com/IngSoft-IOS-2026-1/plugin-individual-martinisrael/issues"
  },
  "homepage": "https://github.com/IngSoft-IOS-2026-1/plugin-individual-martinisrael#readme",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "miranda",
        "aliases": ["Miranda", "miranda"],
        "extensions": [".m"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "miranda",
        "scopeName": "source.miranda",
        "path": "./syntaxes/miranda.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Miranda Prelude",
      "properties": {
        "miranda-preludio.documentationLanguage": {
          "type": "string",
          "enum": ["auto", "en", "es"],
          "enumDescriptions": [
            "%configuration.documentationLanguage.auto%",
            "%configuration.documentationLanguage.en%",
            "%configuration.documentationLanguage.es%"
          ],
          "default": "auto",
          "description": "%configuration.documentationLanguage.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node --test out/test/**/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3"
  }
}
