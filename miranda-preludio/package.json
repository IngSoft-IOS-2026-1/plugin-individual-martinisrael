{
  "name": "miranda-preludio",
  "displayName": "Miranda Prelude",
  "description": "%extension.description%",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "miranda",
        "aliases": ["Miranda", "miranda"],
        "extensions": [".m"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "miranda",
        "scopeName": "source.miranda",
        "path": "./syntaxes/miranda.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Miranda Prelude",
      "properties": {
        "miranda-preludio.documentationLanguage": {
          "type": "string",
          "enum": ["auto", "en", "es"],
          "enumDescriptions": [
            "%configuration.documentationLanguage.auto%",
            "%configuration.documentationLanguage.en%",
            "%configuration.documentationLanguage.es%"
          ],
          "default": "auto",
          "description": "%configuration.documentationLanguage.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
