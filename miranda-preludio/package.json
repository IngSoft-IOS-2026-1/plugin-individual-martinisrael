{
  "name": "miranda-preludio",
  "displayName": "miranda-preludio",
  "description": "Plugin de soporte para el lenguaje Miranda: resaltado, autocompletado y documentación del Preludio estándar.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "miranda",
        "aliases": ["Miranda", "miranda"],
        "extensions": [".m"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "miranda",
        "scopeName": "source.miranda",
        "path": "./syntaxes/miranda.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "miranda-preludio.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
